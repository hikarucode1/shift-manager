# ---- Supabase ----
# プロジェクト URL（Supabase ダッシュボード > Project Settings > API > "Project URL"）
# ⚠️ 末尾の "/rest/v1/" は付けないこと。ベース URL のみ。
#    付けてしまうと Auth リクエストが PostgREST に流れて 404 (PGRST125) で死にます。
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# anon public key (Project Settings > API > "Project API keys" > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service role key (Project Settings > API > "Project API keys" > service_role)
# ⚠️ サーバー専用。絶対にクライアントへ出さない。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Drizzle / Postgres ----
# Project Settings > Database > Connection string > "Transaction pooler" タブの URI
# ⚠️ ポート 6543 (Transaction pooler) を使うこと。5432 だと postgres-js の prepare 設定と衝突する。
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ---- App ----
# タイムゾーン (JST 固定)
TZ=Asia/Tokyo
